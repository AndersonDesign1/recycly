{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist --sourcemap",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@elysiajs/openapi": "latest",
    "@recycly/config": "workspace:*",
    "@recycly/contracts": "workspace:*",
    "drizzle-orm": "latest",
    "elysia": "latest",
    "postgres": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/bun": "latest",
    "drizzle-kit": "latest",
    "typescript": "5.9.2"
  }
}
