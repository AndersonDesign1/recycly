{
  "name": "recycly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:generate": "bun --cwd apps/api run db:generate",
    "db:push": "bun --cwd apps/api run db:push",
    "db:studio": "bun --cwd apps/api run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "ultracite": "7.5.6",
    "@biomejs/biome": "2.4.11"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.10"
  }
}
